	(text "INA226 polarity inversion and\nUV/OV protection circuit"
		(exclude_from_sim no)
		(at 79.756 165.354 0)
		(effects
			(font
				(size 2.032 2.032)
				(thickness 0.3048)
				(bold yes)
			)
		)
		(uuid "ba65f1e1-fcf2-43e7-991d-c4d879e0999f")
	)
	(text "1st stage (polarity inversion protection):\n- Q1: input voltage enters the HL2309 P-MOSFET source\n- D4: 12 V zener to clamp |Vgs| when the source voltage (PSU/PROBE V)\n  rises too far above the gate (0V)\n- R10: pulls PMOS gate to GND (turn on bias when polarity is correct)\n\n2nd stage (UV/OV protection):\n- PMOS drain feeds the INA_VBUS protection stage when polarity\n  is correct\n- R9: 330 Ω resistor limits fault current into the\n  clamp network and INA VBUS\n- D2: SMAJ36A TVS OV protection for INA VBUS pin\n  INA226 VBUS operating range is 0V to 36V (40V abs. max)\n- D3: SS14 Schottky clamps negative voltage. INA226 VBUS abs. min is -0.3V"
		(exclude_from_sim yes)
		(at 55.626 182.626 0)
		(effects
			(font
				(face "Courier New")
				(size 1 1)
				(bold yes)
				(italic yes)
				(color 0 10 190 1)
			)
			(justify left)
		)
		(uuid "c9e55aee-a266-492f-ac59-ef3f2980fbd4")
	)
	(text "USB-UART\nBridge"
		(exclude_from_sim no)
		(at 98.806 90.17 0)
		(effects
			(font
				(size 2.032 2.032)
				(thickness 0.3048)
				(bold yes)
			)
		)
		(uuid "da04a037-7f64-4f56-a70f-5375210d8057")
	)
	(text "(PROBE / PSU_SENSE selection switch):\n- DPDT switch (double pole, double throw)\n- pole 1 common pin connects to MCU GP10 (to be\n  configured as PULLUP)\n- pole 2 common pin connects to INA226\n  Protection Circuit\n- if GP -> high: INA VBUS is reading PSU_IN+ voltage\n- if GP -> low : INA VBUS is reading PROBE+ voltage\n"
		(exclude_from_sim yes)
		(at 243.84 115.316 0)
		(effects
			(font
				(face "Courier New")
				(size 0.889 0.889)
				(bold yes)
				(italic yes)
				(color 190 104 174 1)
			)
			(justify left)
		)
		(uuid "e6251ccb-6cd3-4b7e-80c0-fea87d936353")
	)
